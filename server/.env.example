# Copy to .env and fill in. Never commit real secrets.

# Supabase project (create one free at supabase.com, run schema.sql in the SQL editor)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # server-only, NEVER expose to the app

# Shared secret the app sends as a bearer token (set the same value in app Settings)
SYNC_TOKEN=pick-a-long-random-string

# Resend (free at resend.com) for expiry-alert emails
RESEND_API_KEY=re_xxx

# Flight status — AeroDataBox via RapidAPI (free tier). Powers /api/flight.
AERODATABOX_KEY=your-rapidapi-key

# LLM for messy-itinerary parsing (optional). Powers /api/parse-itinerary.
ANTHROPIC_API_KEY=sk-ant-xxx

# Protects the cron endpoint (Vercel sends this automatically when configured)
CRON_SECRET=another-long-random-string
